[Desktop Entry]
Type=Application
Name=Next meeting
Comment=Show your next Google Calendar event in the COSMIC panel
Exec=cosmic-applet-google-agenda
Icon=com.github.ragusa87.CosmicAppletGoogleAgenda
Terminal=false
Categories=COSMIC;X-COSMIC-Applet;
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
X-OverflowPriority=2
